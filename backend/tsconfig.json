{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",

    "outDir": "./dist",
    "rootDir": "./src",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "sourceMap": true,
    "declaration": true,
    "incremental": true
  },

  "ts-node": {
    "files": true
  },

  "include": ["src/**/*.ts", "src/types/**/*.d.ts", "server.ts"],
  "exclude": ["node_modules", "dist"]
}
